# Rails app — shared infrastructure (Postgres + Redis via Docker Compose)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=chess_mentor
DATABASE_PASSWORD=chess_mentor
DATABASE_NAME=chess_mentor_development

REDIS_URL=redis://localhost:6379/0

# Lichess OAuth (PKCE; no client secret). Redirect URI for local dev:
# http://localhost:3000/users/auth/lichess/callback
LICHESS_CLIENT_ID=chess-mentor-local
