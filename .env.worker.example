# Python analysis worker — not used by Rails
#
# Host dev (worker on your machine, db/redis in Docker):
#   cp .env.worker.example .env.worker
#   DATABASE_HOST=localhost
#
# Docker dev (worker container):
#   docker compose --profile worker up
#   compose overrides DATABASE_HOST, REDIS_URL, and STOCKFISH_PATH — see docker-compose.yml

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=chess_mentor
DATABASE_PASSWORD=chess_mentor
DATABASE_NAME=chess_mentor_development

REDIS_URL=redis://localhost:6379/0

# Host: brew install stockfish → often /opt/homebrew/bin/stockfish (Apple Silicon)
# Docker worker image: /usr/games/stockfish (set in analysis/Dockerfile)
STOCKFISH_PATH=/opt/homebrew/bin/stockfish

WORKER_ID=worker-1
WORKER_POLL_INTERVAL_SECONDS=2
