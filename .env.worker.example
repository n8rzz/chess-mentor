# Python analysis worker — not used by Rails
#
# Host dev (worker on your machine, db/redis in Docker):
#   cp .env.worker.example .env.worker
#   DATABASE_HOST=localhost
#
# Docker dev (worker containers):
#   make workers-up                    # WORKER_REPLICAS from .env (default 1)
#   make workers-up WORKER_REPLICAS=3  # override on the command line
#   compose overrides DATABASE_HOST, REDIS_URL, STOCKFISH_PATH, and WORKER_ID — see docker-compose.yml
#   After pulling worker code changes: make workers-build && make workers-up

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=chess_mentor
DATABASE_PASSWORD=chess_mentor
DATABASE_NAME=chess_mentor_development

REDIS_URL=redis://localhost:6379/0

# Host: brew install stockfish → often /opt/homebrew/bin/stockfish (Apple Silicon)
# Docker worker image: /usr/games/stockfish (set in analysis/Dockerfile)
STOCKFISH_PATH=/opt/homebrew/bin/stockfish

# Host-native worker only; Docker compose clears this so each container uses its hostname.
WORKER_ID=worker-1
WORKER_POLL_INTERVAL_SECONDS=2

# Python tests use a separate database (see Makefile PYTHON_TEST_DATABASE).
# Prepared via: make test-db-python
