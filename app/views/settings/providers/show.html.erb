<% content_for :title, "Providers — Chess Mentor" %>

<h1 class="text-3xl font-bold text-gray-900">Providers</h1>
<p class="mt-2 text-gray-600">Connect your Lichess account to import games for analysis.</p>

<section class="mt-8 max-w-xl rounded-lg border border-gray-200 bg-white p-6">
  <h2 class="text-lg font-semibold text-gray-900">Lichess</h2>
  <% if @lichess_account %>
    <p class="mt-2 text-gray-600">
      Connected as <strong>@<%= @lichess_account.provider_username %></strong>
    </p>
    <% if @lichess_account.last_imported_at.present? %>
      <p class="mt-1 text-sm text-gray-500">
        Last import: <%= l(@lichess_account.last_imported_at, format: :long) %>
      </p>
    <% end %>
    <div class="mt-4 flex flex-wrap gap-3">
      <%= link_to "Import games",
                  new_import_batch_path,
                  class: "inline-block rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white" %>
      <%= button_to "Disconnect",
                    disconnect_settings_providers_path(provider_account_id: @lichess_account.id),
                    method: :delete,
                    form: { data: { turbo_confirm: "Disconnect your Lichess account?" } },
                    class: "inline-block rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700" %>
    </div>
  <% else %>
    <p class="mt-2 text-gray-600">Connect your Lichess account to import games.</p>
    <%= button_to "Connect Lichess",
                  omniauth_authorize_path(:user, :lichess),
                  data: { turbo: false },
                  class: "mt-4 inline-block rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white" %>
  <% end %>
</section>
