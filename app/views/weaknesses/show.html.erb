<% content_for :title, "#{@weakness_cycle.theme_label} — Chess Mentor" %>

<p class="text-sm text-gray-500">
  <%= link_to "Weaknesses", weaknesses_path, class: "underline" %>
</p>

<h1 class="mt-2 text-3xl font-bold text-gray-900"><%= @weakness_cycle.theme_label %></h1>
<p class="mt-2 capitalize text-gray-600">
  Status: <%= @weakness_cycle.status %>
  <% if @weakness_cycle.cycle_number > 1 %>
    · Cycle <%= @weakness_cycle.cycle_number %>
  <% end %>
</p>

<section class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Games affected</p>
    <p class="mt-1 text-lg font-semibold text-gray-900">
      <%= @weakness_cycle.games_affected %> / <%= @weakness_cycle.detection_window_games %>
    </p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Frequency</p>
    <p class="mt-1 text-lg font-semibold text-gray-900"><%= number_to_percentage(@weakness_cycle.frequency * 100, precision: 0) %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Severity</p>
    <p class="mt-1 text-lg font-semibold text-gray-900"><%= number_with_precision(@weakness_cycle.current_severity, precision: 2) %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Detection window</p>
    <p class="mt-1 text-lg font-semibold text-gray-900">
      <%= @weakness_cycle.detection_window_games %> games / <%= @weakness_cycle.detection_window_days %> days
    </p>
  </div>
</section>

<section class="mt-8 overflow-hidden rounded-lg border border-gray-200 bg-white">
  <h2 class="border-b border-gray-200 px-4 py-3 text-lg font-semibold text-gray-900">Linked games and moves</h2>
  <% if @weakness_events.any? %>
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left font-semibold text-gray-900">Game</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-900">Move</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-900">Phase</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-900">Severity</th>
          <th class="px-4 py-3 text-left font-semibold text-gray-900">Time pressure</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @weakness_events.each do |event| %>
          <tr>
            <td class="px-4 py-3">
              <%= link_to(
                    event.game.opponent_username || "Game",
                    game_path(event.game),
                    class: "underline text-gray-900"
                  ) %>
              <span class="text-gray-500">· <%= l(event.game.played_at.to_date) %></span>
            </td>
            <td class="px-4 py-3 font-mono text-gray-900">
              <%= link_to(
                    "#{event.move.move_number}#{event.move.white? ? "." : "..."} #{event.move.san}",
                    game_path(event.game, ply: event.move.ply),
                    class: "underline text-gray-900"
                  ) %>
            </td>
            <td class="px-4 py-3 capitalize text-gray-700"><%= event.phase %></td>
            <td class="px-4 py-3 text-gray-700"><%= number_with_precision(event.severity, precision: 2) %></td>
            <td class="px-4 py-3 text-gray-700"><%= event.occurred_under_time_pressure? ? "Yes" : "No" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="px-4 py-6 text-gray-600">No weakness events recorded for this cycle.</p>
  <% end %>
</section>
