<% content_for :title, "Game — Chess Mentor" %>

<h1 class="text-3xl font-bold text-gray-900">Game analysis</h1>
<p class="mt-2 text-gray-600">
  vs <%= @game.opponent_username || "Unknown" %> · <%= l(@game.played_at.to_date) %>
</p>

<section class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Result</p>
    <p class="mt-1 text-lg font-semibold capitalize text-gray-900"><%= @game.result %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Time class</p>
    <p class="mt-1 text-lg font-semibold capitalize text-gray-900"><%= @game.time_class %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Opening</p>
    <p class="mt-1 text-lg font-semibold text-gray-900"><%= @game.opening_name || "Unknown" %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Analysis</p>
    <p class="mt-1 text-lg font-semibold capitalize text-gray-900">
      <%= @analysis_run ? @analysis_run.status.tr("_", " ") : "Not started" %>
    </p>
  </div>
</section>

<% if @analysis_run&.pending? || @analysis_run&.running? %>
  <section class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
    <p class="text-sm text-amber-900">
      Analysis is queued or in progress...
    </p>
  </section>
<% end %>

<% if @analysis_run&.error_message.present? %>
  <section class="mt-6 rounded-lg border border-red-200 bg-red-50 p-4">
    <h2 class="font-semibold text-red-900">Analysis error</h2>
    <p class="mt-2 text-sm text-red-800"><%= @analysis_run.error_message %></p>
  </section>
<% end %>

<section class="mt-6 overflow-hidden rounded-lg border border-gray-200 bg-white">
  <h2 class="border-b border-gray-200 px-4 py-3 text-lg font-semibold text-gray-900">Moves</h2>
  <table class="min-w-full divide-y divide-gray-200 text-sm">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left font-semibold text-gray-900">#</th>
        <th class="px-4 py-3 text-left font-semibold text-gray-900">Move</th>
        <th class="px-4 py-3 text-left font-semibold text-gray-900">Classification</th>
        <th class="px-4 py-3 text-left font-semibold text-gray-900">CPL</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @moves.each do |move| %>
        <% evaluation = @evaluations_by_move_id[move.id] %>
        <tr class="<%= move.played_by_user? ? "bg-amber-50/40" : "" %>">
          <td class="px-4 py-3 text-gray-700"><%= move.move_number %><%= move.white? ? "." : "..." %></td>
          <td class="px-4 py-3 font-mono text-gray-900"><%= move.san %></td>
          <td class="px-4 py-3 capitalize text-gray-700">
            <% if evaluation %>
              <%= evaluation.classification %>
            <% elsif move.played_by_user? %>
              <span class="text-gray-500">Pending</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-gray-700">
            <%= evaluation&.centipawn_loss %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<div class="mt-6 flex gap-3">
  <%= link_to "All games", games_path, class: "text-gray-900 underline" %>
  <%= link_to "Dashboard", dashboard_path, class: "text-gray-900 underline" %>
</div>
