<h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
<p class="mt-2 text-gray-600">Your coaching hub. Import games to begin analysis.</p>

<section class="mt-8 grid gap-6 md:grid-cols-2">
  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-gray-900">Providers</h2>
    <% if @lichess_account %>
      <p class="mt-2 text-gray-600">
        Lichess connected as <strong>@<%= @lichess_account.provider_username %></strong>
      </p>
      <div class="mt-4 flex flex-wrap gap-3 items-center">
        <%= link_to "Import games", new_import_batch_path, class: "inline-block rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white" %>
        <%= link_to "View games", games_path, class: "inline-block rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-900" %>
        <%= link_to "Manage providers", settings_providers_path, class: "text-sm underline text-gray-700" %>
      </div>
    <% else %>
      <p class="mt-2 text-gray-600">Connect your Lichess account to import games.</p>
      <%= link_to "Connect Lichess",
                  settings_providers_path,
                  class: "mt-4 inline-block rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white" %>
    <% end %>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-gray-900">Recent imports</h2>
    <% if @latest_import_batch %>
      <p class="mt-2 capitalize text-gray-600">
        <%= @latest_import_batch.status.tr("_", " ") %> —
        <%= @latest_import_batch.games_imported_count %> imported
      </p>
      <%= link_to "View import", import_batch_path(@latest_import_batch), class: "mt-2 inline-block text-sm underline text-gray-700" %>
    <% else %>
      <p class="mt-2 text-gray-500">No imports yet.</p>
    <% end %>
    <%= link_to "All imports", import_batches_path, class: "mt-4 inline-block text-sm underline text-gray-700" %>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-gray-900">Training plan</h2>
    <p class="mt-2 text-gray-500">No active plan.</p>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-gray-900">Recurring weaknesses</h2>
    <% if @top_weakness_cycles.any? %>
      <ul class="mt-3 space-y-2 text-sm text-gray-700">
        <% @top_weakness_cycles.each do |cycle| %>
          <li class="flex items-center justify-between gap-4">
            <%= link_to cycle.theme_label, weakness_path(cycle), class: "font-medium text-gray-900 underline" %>
            <span class="shrink-0 text-gray-500">
              <%= cycle.games_affected %>/<%= cycle.detection_window_games %> games ·
              <%= number_to_percentage(cycle.frequency * 100, precision: 0) %>
            </span>
          </li>
        <% end %>
      </ul>
      <%= link_to "View all weaknesses", weaknesses_path, class: "mt-4 inline-block text-sm underline text-gray-700" %>
    <% else %>
      <p class="mt-2 text-gray-500">Analyze games to surface recurring patterns.</p>
      <%= link_to "View games", games_path, class: "mt-4 inline-block text-sm underline text-gray-700" %>
    <% end %>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-gray-900">Progress</h2>
    <p class="mt-2 text-gray-500">Check back after your first analysis.</p>
  </div>
</section>
