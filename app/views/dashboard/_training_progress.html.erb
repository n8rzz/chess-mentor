<% training = @dashboard_summary.training_today %>
<% plan = training.plan %>

<div class="rounded-lg border border-gray-200 bg-white p-6">
  <h2 class="text-lg font-semibold text-gray-900">Training plan</h2>

  <% if plan %>
    <% progress = plan.progress_percentage.to_f %>
    <% improving_threshold = (plan.improvement_threshold || TrainingPlan::DEFAULT_IMPROVEMENT_THRESHOLD) * 100 %>
    <% managed_threshold = (plan.managed_threshold || TrainingPlan::DEFAULT_MANAGED_THRESHOLD) * 100 %>

    <p class="mt-2 text-gray-700">
      <span class="text-sm text-gray-500">Objective</span><br>
      <strong><%= plan.theme_label %></strong>
      <span class="capitalize text-gray-500">· <%= plan.status %></span>
    </p>

    <p class="mt-3 text-sm text-gray-600">
      Today's tasks:
      <strong><%= training.assignments_completed %>/<%= training.assignments_total %> completed</strong>
      <% if training.assignments_due_overdue.positive? %>
        <span class="text-amber-700">· <%= training.assignments_due_overdue %> overdue</span>
      <% end %>
    </p>

    <% if plan.days_remaining.present? %>
      <p class="mt-1 text-sm text-gray-500"><%= plan.days_remaining %> days remaining</p>
    <% end %>

    <div class="mt-4">
      <div class="flex items-center justify-between text-xs text-gray-500">
        <span>Progress toward weakness reduction</span>
        <span class="font-medium text-gray-700"><%= number_to_percentage(progress, precision: 0) %></span>
      </div>
      <div class="relative mt-2 h-3 overflow-hidden rounded-full bg-gray-100">
        <div class="h-full rounded-full bg-gray-900" style="width: <%= [ progress, 100 ].min %>%"></div>
        <div class="absolute inset-y-0 w-px bg-amber-400" style="left: <%= improving_threshold %>%"></div>
        <div class="absolute inset-y-0 w-px bg-emerald-500" style="left: <%= managed_threshold %>%"></div>
      </div>
      <div class="mt-1 flex justify-between text-xs text-gray-500">
        <span>Active</span>
        <span><%= number_to_percentage(improving_threshold, precision: 0) %> improving</span>
        <span><%= number_to_percentage(managed_threshold, precision: 0) %> managed</span>
      </div>
    </div>

    <div class="mt-4 flex flex-wrap gap-3">
      <%= link_to "View plan", training_plan_path(plan), class: "inline-block text-sm underline text-gray-700" %>
      <%= link_to "Today's assignments", today_training_plan_path(plan), class: "inline-block text-sm underline text-gray-700" %>
    </div>
  <% else %>
    <p class="mt-2 text-gray-500">No active plan.</p>
    <%= link_to "Browse recommendations", training_plans_path, class: "mt-4 inline-block text-sm underline text-gray-700" %>
  <% end %>
</div>
