<% progress = @dashboard_progress %>
<% chart_cards = dashboard_chart_cards(progress) %>

<section class="mt-8">
  <h2 class="text-lg font-semibold text-gray-900">Progress charts</h2>

  <% if chart_cards.any? %>
    <div class="mt-4 grid gap-6 md:grid-cols-2">
      <% chart_cards.each do |card| %>
        <div class="rounded-lg border border-gray-200 bg-white p-4">
          <h3 class="text-sm font-medium text-gray-900"><%= card[:label] %></h3>
          <div
            class="mt-3 h-56"
            data-controller="chart"
            data-chart-type-value="line"
            data-chart-label-value="<%= card[:label] %>"
            data-chart-series-value="<%= card[:series].to_json %>"
          >
            <canvas role="img" aria-label="<%= card[:label] %> chart"></canvas>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="mt-2 text-sm text-gray-500">Trend charts appear after multiple progress snapshots are recorded.</p>
  <% end %>
</section>
