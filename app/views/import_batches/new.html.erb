<% content_for :title, "Import Games — Chess Mentor" %>

<h1 class="text-3xl font-bold text-gray-900">Import games</h1>
<p class="mt-2 text-gray-600">
  Import up to 30 recent games from Lichess as <strong>@<%= @lichess_account.provider_username %></strong>.
</p>

<%= form_with url: import_batches_path, scope: :import, method: :post, class: "mt-8 max-w-xl space-y-6" do |form| %>
  <fieldset class="rounded-lg border border-gray-200 bg-white p-6">
    <legend class="text-lg font-semibold text-gray-900 px-1">Date range</legend>
    <div class="mt-4 space-y-2">
      <% ImportBatches::Create::ALLOWED_DAYS.each do |days| %>
        <label class="flex items-center gap-2 text-gray-700">
          <%= form.radio_button :days, days, checked: days == 7, class: "rounded border-gray-300" %>
          Last <%= days %> days
        </label>
      <% end %>
    </div>
  </fieldset>

  <fieldset class="rounded-lg border border-gray-200 bg-white p-6">
    <legend class="text-lg font-semibold text-gray-900 px-1">Time controls</legend>
    <div class="mt-4 grid grid-cols-2 gap-2">
      <% ImportBatches::Create::ALLOWED_TIME_CONTROLS.each do |control| %>
        <label class="flex items-center gap-2 text-gray-700 capitalize">
          <%= form.check_box :time_controls, { multiple: true, checked: %w[blitz rapid].include?(control), class: "rounded border-gray-300" }, control, nil %>
          <%= control %>
        </label>
      <% end %>
    </div>
  </fieldset>

  <div class="rounded-lg border border-gray-200 bg-white p-6">
    <%= form.label :max_games, "Maximum games", class: "text-lg font-semibold text-gray-900" %>
    <%= form.number_field :max_games,
                          value: ImportBatches::Create::MAX_GAMES_LIMIT,
                          min: 1,
                          max: ImportBatches::Create::MAX_GAMES_LIMIT,
                          class: "mt-2 block w-24 rounded-lg border border-gray-300 px-3 py-2" %>
    <p class="mt-1 text-sm text-gray-500">Between 1 and <%= ImportBatches::Create::MAX_GAMES_LIMIT %>.</p>
  </div>

  <div class="flex gap-3">
    <%= form.submit "Start import", class: "rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white cursor-pointer" %>
    <%= link_to "Cancel", settings_providers_path, class: "rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700" %>
  </div>
<% end %>
