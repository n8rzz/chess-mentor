<% content_for :title, "Training plans — Chess Mentor" %>

<h1 class="text-3xl font-bold text-gray-900">Training plans</h1>
<p class="mt-2 text-gray-600">Focus on one weakness at a time with daily practice assignments.</p>

<% if @current_plan %>
  <section class="mt-8 rounded-lg border border-gray-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-gray-900">Current plan</h2>
    <p class="mt-2 text-gray-700">
      <strong><%= @current_plan.theme_label %></strong>
      <span class="capitalize text-gray-500">· <%= @current_plan.status %></span>
    </p>
    <p class="mt-1 text-sm text-gray-600">
      Progress: <%= number_to_percentage(@current_plan.progress_percentage || 0, precision: 0) %>
      <% if @current_plan.ends_at.present? %>
        · <%= @current_plan.days_remaining %> days remaining
      <% end %>
    </p>
  <div class="mt-4 flex flex-wrap gap-3">
      <%= link_to "View plan", training_plan_path(@current_plan), class: "inline-block rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white" %>
      <%= link_to "Today's assignments", today_training_plan_path(@current_plan), class: "inline-block rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-900" %>
    </div>
  </section>
<% elsif @recommendations.any? %>
  <section class="mt-8 overflow-hidden rounded-lg border border-gray-200 bg-white">
    <div class="border-b border-gray-200 bg-gray-50 px-4 py-3">
      <h2 class="text-lg font-semibold text-gray-900">Recommended plans</h2>
      <p class="text-sm text-gray-600">Choose one weakness to work on for the next 14 days.</p>
    </div>
    <ul class="divide-y divide-gray-200">
      <% @recommendations.each do |cycle| %>
        <li class="flex flex-wrap items-center justify-between gap-4 px-4 py-4">
          <div>
            <p class="font-medium text-gray-900"><%= cycle.theme_label %></p>
            <p class="text-sm text-gray-600">
              Severity <%= number_with_precision(cycle.current_severity, precision: 2) %>
              · <%= cycle.games_affected %>/<%= cycle.detection_window_games %> games
            </p>
          </div>
          <%= button_to "Start plan",
                        training_plans_path(weakness_cycle_id: cycle.id),
                        method: :post,
                        class: "rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white" %>
        </li>
      <% end %>
    </ul>
  </section>
<% else %>
  <section class="mt-8 rounded-lg border border-gray-200 bg-white p-6">
    <p class="text-gray-600">No training recommendations yet. Analyze games to surface recurring weaknesses.</p>
    <%= link_to "View weaknesses", weaknesses_path, class: "mt-4 inline-block text-sm underline text-gray-700" %>
  </section>
<% end %>
