<% content_for :title, "Today's training — Chess Mentor" %>

<%= link_to "← Plan overview", training_plan_path(@training_plan), class: "text-sm text-gray-600 underline" %>

<h1 class="mt-4 text-3xl font-bold text-gray-900">Today's assignments</h1>
<p class="mt-2 text-gray-600"><%= @training_plan.theme_label %> · <%= Date.current.strftime("%B %-d, %Y") %></p>

<% if @assignments.any? %>
  <ul class="mt-8 space-y-4">
    <% @assignments.each do |assignment| %>
      <li class="rounded-lg border border-gray-200 bg-white p-4">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="font-semibold capitalize text-gray-900"><%= assignment.assignment_type.humanize %></p>
            <% if assignment.prompt.present? %>
              <p class="mt-1 text-sm text-gray-700"><%= assignment.prompt %></p>
            <% end %>
            <% if assignment.puzzle.present? %>
              <p class="mt-2 text-xs text-gray-500">Puzzle · <%= assignment.puzzle.difficulty %> · rating <%= assignment.puzzle.rating %></p>
            <% end %>
            <% if assignment.source_game.present? %>
              <p class="mt-2 text-xs text-gray-500">From game vs <%= assignment.source_game.opponent_username %></p>
            <% end %>
            <p class="mt-2 capitalize text-sm text-gray-500">Status: <%= assignment.status %></p>
          </div>
          <% if assignment.pending? %>
            <div class="flex flex-wrap gap-2">
              <% if assignment.theme_puzzle? || assignment.personal_position_review? %>
                <%= link_to "Start",
                            training_plan_training_assignment_path(@training_plan, assignment),
                            class: "rounded-lg bg-gray-900 px-3 py-2 text-sm font-medium text-white" %>
              <% end %>
              <%= button_to "Complete",
                            complete_training_plan_training_assignment_path(@training_plan, assignment),
                            method: :patch,
                            class: "rounded-lg bg-gray-900 px-3 py-2 text-sm font-medium text-white" %>
              <%= button_to "Skip",
                            skip_training_plan_training_assignment_path(@training_plan, assignment),
                            method: :patch,
                            class: "rounded-lg border border-gray-300 px-3 py-2 text-sm font-medium text-gray-900" %>
            </div>
          <% end %>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <section class="mt-8 rounded-lg border border-gray-200 bg-white p-6">
    <p class="text-gray-600">No assignments scheduled for today.</p>
  </section>
<% end %>
