<% content_for :title, "#{@training_plan.theme_label} plan — Chess Mentor" %>

<%= link_to "← Training plans", training_plans_path, class: "text-sm text-gray-600 underline" %>

<h1 class="mt-4 text-3xl font-bold text-gray-900"><%= @training_plan.theme_label %> training plan</h1>
<p class="mt-2 capitalize text-gray-600">Status: <%= @training_plan.status %></p>

<section class="mt-6 grid gap-4 md:grid-cols-3">
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Progress</p>
    <p class="mt-1 text-2xl font-semibold text-gray-900">
      <%= number_to_percentage(@training_plan.progress_percentage || 0, precision: 0) %>
    </p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Baseline occurrences</p>
    <p class="mt-1 text-2xl font-semibold text-gray-900"><%= @training_plan.baseline_occurrences %></p>
  </div>
  <div class="rounded-lg border border-gray-200 bg-white p-4">
    <p class="text-sm text-gray-500">Current occurrences</p>
    <p class="mt-1 text-2xl font-semibold text-gray-900"><%= @training_plan.current_occurrences %></p>
  </div>
</section>

<div class="mt-6 flex flex-wrap gap-3">
  <%= link_to "Today's assignments", today_training_plan_path(@training_plan), class: "inline-block rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white" %>
  <% if @training_plan.active? %>
    <%= button_to "Pause", pause_training_plan_path(@training_plan), method: :post, class: "rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-900" %>
  <% elsif @training_plan.paused? %>
    <%= button_to "Resume", resume_training_plan_path(@training_plan), method: :post, class: "rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-900" %>
  <% end %>
  <% unless @training_plan.completed? || @training_plan.archived? %>
    <%= button_to "Complete", complete_training_plan_path(@training_plan), method: :post, class: "rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-900" %>
    <%= button_to "Archive", archive_training_plan_path(@training_plan), method: :post, class: "rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-900" %>
  <% end %>
  <% if @training_plan.eligible_for_extension? %>
    <%= button_to "Extend 14 days", extend_training_plan_path(@training_plan), method: :post, class: "rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-900" %>
  <% end %>
</div>

<% if @generation_pending %>
  <section class="mt-8 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
    Assignments are still being generated. Refresh this page in a moment.
  </section>
<% elsif @assignments_by_day.any? %>
  <section class="mt-8 space-y-6">
    <% @assignments_by_day.each do |due_on, assignments| %>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-lg font-semibold text-gray-900">
          <%= due_on == Date.current ? "Today" : due_on.strftime("%B %-d, %Y") %>
        </h2>
        <ul class="mt-3 space-y-2 text-sm text-gray-700">
          <% assignments.each do |assignment| %>
            <li class="flex items-center justify-between gap-4">
              <span>
                <span class="capitalize font-medium text-gray-900"><%= assignment.assignment_type.humanize %></span>
                <% if assignment.prompt.present? %>
                  — <%= assignment.prompt %>
                <% end %>
                <span class="capitalize text-gray-500">(<%= assignment.status %>)</span>
              </span>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </section>
<% end %>
