<h1 class="text-3xl font-bold">Chess Mentor</h1>

<% if user_signed_in? %>
  <p class="mt-4">Signed in as <strong><%= current_user.username %></strong> (<%= current_user.email %>).</p>
  <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "mt-4 underline" %>
<% else %>
  <p class="mt-4">
    <%= link_to "Sign in", new_user_session_path, class: "underline" %>
    or
    <%= link_to "Sign up", new_user_registration_path, class: "underline" %>
  </p>
<% end %>
